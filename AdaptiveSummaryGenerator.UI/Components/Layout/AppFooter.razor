@inject AppState AppState
@implements IDisposable

<footer class="asg-footer">
    <div class="footer-left">
        <i class="bi bi-headset"></i>
        <a href="mailto:support@asg.dev" class="footer-link">Contact Support</a>
    </div>

    <div class="footer-center">
        <span>@DateTime.Now.ToString("MMM dd, yyyy")</span>
        <span class="footer-sep">|</span>
        <label class="thought-toggle">
            <i class="bi bi-cpu"></i>
            Show AI Thought Process
            <div class="toggle-switch">
                <input type="checkbox"
                       checked="@AppState.ShowThoughtProcess"
                       @onchange="ToggleThoughtProcess" />
                <span class="toggle-slider"></span>
            </div>
        </label>
    </div>

    <div class="footer-right">
        <span>&copy; @DateTime.Now.Year Adaptive Summary. All Rights Reserved.</span>
    </div>
</footer>

@code {
    protected override void OnInitialized()
    {
        AppState.OnThoughtProcessChanged += StateHasChanged;
    }

    private void ToggleThoughtProcess()
    {
        AppState.ShowThoughtProcess = !AppState.ShowThoughtProcess;
    }

    public void Dispose()
    {
        AppState.OnThoughtProcessChanged -= StateHasChanged;
    }
}
