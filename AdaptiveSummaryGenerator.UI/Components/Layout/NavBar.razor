@inject AppState AppState

<nav class="asg-navbar">
    <div class="navbar-brand">
        <div class="brand-icon">
            <i class="bi bi-file-text-fill"></i>
        </div>
        <div class="brand-text">
            <span class="brand-title">Adaptive Summary Generator</span>
            <span class="brand-subtitle">AI-Powered Smart Summarization</span>
        </div>
    </div>

    <div class="navbar-actions">
        <button class="btn-about" @onclick="OnAboutClick">
            <i class="bi bi-info-circle"></i>
            About
        </button>
    </div>
</nav>

@code {
    // Raise event so MainLayout can show the About modal
    [Parameter] public EventCallback OnAboutClick { get; set; }
}
